    "class Solution(object):\n",
    "    def runningSum(self, nums):\n",
    "        for i in range(len(nums) - 1):\n",
    "            nums[i + 1] += nums[i]\n",
    "        return nums\n",
    "        \"\"\"\n",
    "        :type nums: List[int]\n",
    "        :rtype: List[int]\n",
